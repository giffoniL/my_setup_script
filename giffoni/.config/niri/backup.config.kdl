// Check the wiki for a full description of the configuration:
// https://yalter.github.io/niri/Configuration:-Introduction


// ─────────────────────────────────────────────
// ENVIRONMENT
// ─────────────────────────────────────────────

environment {
    XDG_CURRENT_DESKTOP          "niri"
    TERMINAL                     "foot"
    QT_QPA_PLATFORM              "wayland"
    QT_QPA_PLATFORMTHEME         "gtk3"
    QT_QPA_PLATFORMTHEME_QT6     "gtk3"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
}


// ─────────────────────────────────────────────
// STARTUP
// ─────────────────────────────────────────────

// Wallpaper & compositor extras
spawn-sh-at-startup "awww-daemon"
spawn-sh-at-startup "awww-daemon -n overview"
// spawn-sh-at-startup "awww img $HOME/Pictures/Wallpaper/wallpaper.jpg"
// spawn-sh-at-startup "awww img -n overview $HOME/Pictures/Wallpaper/wallpaper.jpg"

// Polkit authentication agent
spawn-sh-at-startup "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"

// GNOME/GTK settings
spawn-sh-at-startup "gsettings set org.gnome.desktop.interface color-scheme prefer-dark"
spawn-sh-at-startup "gsettings set org.gnome.desktop.interface gtk-theme Adwaita"
spawn-sh-at-startup "gsettings set org.gnome.desktop.interface icon-theme Reversal-blue"
spawn-sh-at-startup "gsettings set org.gnome.desktop.interface font-name 'Adwaita Sans 11'"
spawn-sh-at-startup "gsettings set org.gnome.desktop.interface monospace-font-name 'Adwaita Mono 11'"
spawn-sh-at-startup "gsettings set org.gnome.desktop.interface cursor-theme macOS"
spawn-sh-at-startup "gsettings set org.gnome.desktop.interface cursor-size 40"


// ─────────────────────────────────────────────
// INPUT
// ─────────────────────────────────────────────

input {
    keyboard {
        xkb {
            layout "us(altgr-intl)"
        }
        numlock
    }

    touchpad {
        tap
        natural-scroll
        // off
        // dwt
        // dwtp
        // drag false
        // drag-lock
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "two-finger"
        // disabled-on-external-mouse
    }

    mouse {
    }

    trackpoint {
    }
}


// ─────────────────────────────────────────────
// OUTPUTS
// ─────────────────────────────────────────────

output "eDP-1" {
    mode      "1920x1080@60.000"
    scale     1
    transform "normal"
}


// ─────────────────────────────────────────────
// CURSOR
// ─────────────────────────────────────────────

cursor {
    xcursor-theme    "macOS-White"
    xcursor-size     40
    hide-after-inactive-ms 10000
}


// ─────────────────────────────────────────────
// LAYOUT
// ─────────────────────────────────────────────

layout {
    gaps 8

    center-focused-column "never"

    default-column-width { proportion 1.0; }

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    preset-window-heights {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    focus-ring {
        off
        width 3
        active-color  "#FF8170"
        inactive-color "#505050"
    }

    border {
        off
        width 2
    }

    shadow {
    	on
        softness 0
        spread   0
        offset x=5 y=5
        color "#000000"
    }
}


// ─────────────────────────────────────────────
// OVERVIEW
// ─────────────────────────────────────────────

overview {
    zoom 0.75
    workspace-shadow {
        on
    }
}


// ─────────────────────────────────────────────
// ANIMATIONS
// ─────────────────────────────────────────────

animations {
    workspace-switch {
        spring damping-ratio=0.80 stiffness=523 epsilon=0.0001
    }

    horizontal-view-movement {
        spring damping-ratio=0.85 stiffness=423 epsilon=0.0001
    }

    window-open {
        duration-ms 150
        curve "ease-out-expo"
    }

    window-close {
        duration-ms 150
        curve "ease-out-quad"
    }

    window-movement {
        spring damping-ratio=0.75 stiffness=323 epsilon=0.0001
    }

    window-resize {
        spring damping-ratio=0.85 stiffness=423 epsilon=0.0001
    }

    overview-open-close {
        spring damping-ratio=0.85 stiffness=800 epsilon=0.0001
    }

    config-notification-open-close {
        spring damping-ratio=0.65 stiffness=923 epsilon=0.001
    }

    screenshot-ui-open {
        duration-ms 200
        curve "ease-out-quad"
    }
}


// ─────────────────────────────────────────────
// WORKSPACES
// ─────────────────────────────────────────────

workspace "vesktop"
workspace "firefox"
workspace "task"
workspace "music"


// ─────────────────────────────────────────────
// WINDOW & LAYER RULES
// ─────────────────────────────────────────────

// Global geometry
window-rule {
    geometry-corner-radius 16
    clip-to-geometry true
}

// Startup workspace assignments
window-rule {
    match at-startup=true app-id="vesktop"
    open-on-workspace "vesktop"
}

window-rule {
    match at-startup=true app-id="firefox"
    open-on-workspace "firefox"
}

window-rule {
    match at-startup=true app-id="dev.zed.Zed"
    open-on-workspace "task"
}

window-rule {
    match at-startup=true app-id="foot"
    open-on-workspace "music"
}

// blur terminal background
window-rule {
    match app-id="^foot$"
    background-effect {
        blur true
    }
}

// firefox picture-in-picture fix
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

// fixes Steam toast notifications
window-rule {
    match app-id="steam" title=r#"^notificationtoasts_\d+_desktop$"#
    default-floating-position x=10 y=10 relative-to="bottom-right"
}

// awww overview wallpaper setup
layer-rule {
    match namespace="^awww-daemonoverview$"
    place-within-backdrop true
}

//layer-rule {
//    match namespace="^awww-daemon$"
//    place-within-backdrop false
//}


// ─────────────────────────────────────────────
// KEYBINDINGS
// ─────────────────────────────────────────────

binds {

    // — Applications —
    Mod+Return { spawn "foot"; }
    Mod+D      { spawn "fuzzel"; }

    // — Overview —
    Mod+O repeat=false { toggle-overview; }

    // — Windows —
    Mod+Q repeat=false { close-window; }
    Mod+S              { toggle-window-floating; }
    Mod+C              { center-column; }

    // — Column / Window sizing —
    Mod+R              { switch-preset-column-width; }
    Mod+Shift+R        { switch-preset-window-height; }
    Mod+F              { maximize-column; }
    Mod+Shift+F        { fullscreen-window; }
    Mod+Minus          { set-column-width "-10%"; }
    Mod+Equal          { set-column-width "+10%"; }
    Mod+Shift+Minus    { set-window-height "-10%"; }
    Mod+Shift+Equal    { set-window-height "+10%"; }
    Mod+Comma          { consume-or-expel-window-left; }
    Mod+Period         { consume-or-expel-window-right; }

    // — Focus movement —
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up    { focus-window-up; }
    Mod+Down  { focus-window-down; }

    // — Window movement —
    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Right { move-column-right; }
    Mod+Ctrl+Up    { move-window-up; }
    Mod+Ctrl+Down  { move-window-down; }

    // — Workspace focus —
    Mod+Page_Up   { focus-workspace-up; }
    Mod+Page_Down { focus-workspace-down; }
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    // — Move column to workspace —
    Mod+Ctrl+Page_Up   { move-column-to-workspace-up; }
    Mod+Ctrl+Page_Down { move-column-to-workspace-down; }
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }

    // — Scroll gestures —
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+Shift+WheelScrollUp                  { focus-column-left; }
    Mod+Shift+WheelScrollDown                { focus-column-right; }
    Mod+TouchpadScrollUp   { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.02-"; }
    Mod+TouchpadScrollDown { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.02+"; }

    // — Media: playback —
    Mod+BracketLeft  { spawn "mpc" "prev"; }
    Mod+BracketRight { spawn "mpc" "next"; }
    XF86AudioPlay allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioStop allow-when-locked=true { spawn-sh "playerctl stop"; }
    XF86AudioPrev allow-when-locked=true { spawn-sh "playerctl previous"; }
    XF86AudioNext allow-when-locked=true { spawn-sh "playerctl next"; }

    // — Media: volume —
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+ -l 1.0"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    // — Brightness —
    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }

    // — Screenshot —
    Mod+P { screenshot; }

    // — System —
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
    Ctrl+Alt+Delete                   { power-off-monitors; }
}


// ─────────────────────────────────────────────
// MISC
// ─────────────────────────────────────────────

prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

hotkey-overlay {
    skip-at-startup
}
